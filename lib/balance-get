function
  _global_variables() {
  app_name =
    "balance-get";
  /* global
       wallet_seed:
         writable */
  wallet_seed =
    "";
  /* global
       target_network:
         writable */
  target_network =
    "";
  /* global
       api_key:
         writable */
  api_key =
    "";
  /* global
       target_address:
         writable */
  target_address =
    "";
  /* global
       display_unit:
         writable */
  display_unit =
    "";
  /* global
       output_file:
         writable */
  output_file =
    "";
  /* global
       retries_max:
         writable */
  retries_max =
    "";
  /* global
       quiet:
         writable */
  quiet =
    "";
}


async function
  _balance_get(
    _wallet_seed,
    _target_network,
    _api_key_path,
    _target_address,
    _display_unit,
    _output_file,
    _retries_max,
    _call_timeout) {
  let
    _balance,
    _balance_ether,
    _balance_wei,
    _msg,
    _provider_get_opts,
    _retry,
    _request,
    _success,
    _wallet_dir,
    _wallet_password,
    _wallet_path_list;
  if ( typeof(
         _retries_max) == 'undefined' ||
       _retries_max == "" ) {
    _retries_max =
      3;
  }
  else {
    _retries_max =
      Number(
        _retries_max);
  }
  if ( typeof(
         _call_timeout) == 'undefined' ||
       _call_timeout == "" ) {
    _call_timeout =
      100000;
  }
  _retry =
    0;
  _success =
    false;
  _wallet_password =
    "";
  if ( _wallet_seed != "" ) {
    _wallet_dir =
      _dirname(
        _wallet_seed);
    _wallet_path_list = [
      _wallet_dir,
      "wallet.dat"
    ];
    _wallet_path =
      _path_join(
        _wallet_path_list);
  }
  _provider_get_opts = [
    _target_network,
  ];
  if ( _output_file == undefined ) {
    _output_file =
      "";
  }
  if ( _api_key_path != "" ) {
    _api_key =
      _file_read(
        _api_key_path);
    _provider_get_opts.push(
      _api_key);
  }
  _provider_get_opts.push(
    _call_timeout);
  _provider =
    _provider_get.apply(
      null,
      _provider_get_opts);
  _msg_info_provider_generated(
    _provider);
  if ( _target_address == "" ) {
    _wallet_get_opts = [
      _wallet_path,
      _wallet_password,
      _wallet_seed,
      _provider
    ];
    _wallet =
      _wallet_get.apply(
        null,
        _wallet_get_opts);
    _target_address =
      _wallet.address;
  }
  while ( _success == false &&
          _retry < _retries_max ) {
    try {
      const
        _provider_get_balance_args = [
          _target_address
        ];
      _balance_wei =
        _run(
          _provider.getBalance,
          _provider_get_balance_args,
          "_provider_get_balance",
          _call_timeout,
          "native");
      // _balance_wei = await
      //   _provider.getBalance(
      //     _target_address);
      if ( _display_unit == "" ) {
        _display_unit =
          "ether";
      }
      if ( _display_unit == "wei" ) {
        _balance =
          _balance_wei;
      }
      else if ( _display_unit == "ether" ) {
        _balance_ether =
          _wei_to_ether(
            _balance_wei);
        _balance =
          _balance_ether;
      }
      if ( _output_file != "" ) {
          _file_write(
            _output_file,
            _balance.toString());
      }
      _success =
        true;
    } catch(
        _err) {
      _retry =
        _retry + 1;
      _msg =
        `Error retrieving balance, retrying (${_retry} of ${_retries_max})`;
      console.error(
        _err);
      _msg_error(
        _msg,
        0);
      await _sleep(
        3000);
    }
  }
  if ( _success == false &&
       _retry == _retries_max ) {
    _msg =
      "Error retrieving balance.";
    throw _msg;
    return _balance;
  }
  return _balance;
}

function
  _overrides_set() {
  if ( typeof(
         display_unit) == "undefined" ||
       display_unit == "" ) {
    display_unit =
      "ether";
  }
  if ( typeof(
         retries_max) == "undefined" ||
       retries_max == "" ) {
    retries_max =
      "1";
  }
  if ( typeof(
         call_timeout) == "undefined" ||
       call_timeout == "" ) {
    call_timeout =
      "30000";
  }
}

function
  _config_show() {
  let
    _line;
  const
    _argv =
      _argv_get();
  const
    _program =
      _basename(
        _argv[
          "$0"]);
  const
    _text = [
      `  ${_program} configuration:`,
      `      Wallet seed: ${wallet_seed}`,
      `   Target network: ${target_network}`,
      `          API Key: ${api_key}`,
      `   Target address: ${target_address}`,
      `     Display unit: ${display_unit}`,
      `      Output file: ${output_file}`,
      `  Maximum retries: ${retries_max}`
      `     Call timeout: ${call_timeout}`
    ];
  for ( _line of _text ) {
    _msg_info(
      _line);
  }
}

function
  _usage(
    _exit_code) {
  let
    _line;
  if ( typeof(
         _exit_code) == "undefined" ||
       _exit_code == "" ) {
    _exit_code =
      0;
  }
  const
    _argv =
      _argv_get();
  const
    _program =
      _basename(
        _argv[
          "$0"]);
  const
    _text = [
      "Usage:",
      `  ${_program}`,
      "    <quiet>",
      "    <seed-path>",
      "    <target-network>",
      "    (<api-keys-path)",
      "    (<target-address>)",
      "    (<display-unit>)",
      "    (<output-file>)",
      "    (<retries-max>)",
      "    (<call-timeout>)",
      "",
      "Arguments:",
      "",
      "  <seed-path>         Path on disk of the file",
      "                      containing the seed phrase.",
      "",
      "  <target-network>    Name, chain ID or RPC address",
      "                      of the network to connect to.",
      "",
      "Optional arguments:",
      "",
      "  <api-key-path>      Path on disk of the API key for",
      "                      the network service provider.",
      "",
      "  <target-address>    Address of which to return",
      "                      the balance of.",
      "                      Default: the wallet address.",
      "                      corresponding to the seed.",
      "",
      "  <display-unit>      Can be 'wei' or 'ether'.",
      `                      Default: '${display_unit}'`,
      "",
      "  <output-file>       File in which to save the balance.",
      `                      Default: '${output_file}'`,
      "",
      "  <retries-max>       Maximum number of retries.",
      `                      Default: ${retries_max}`,
      "",
      "  <call-timeout>      Timeout before declaring the call failed.",
      `                      Default: ${call-timeout}`,
  ];
  for ( _line of _text ) {
    console.log(
      _line);
  }
  _process_exit(
    _exit_code);
}


function _cmdline_parse() {
  let
    _msg;
  quiet =
    "y";
  process.argv.forEach(
    function (
      _value,
      _index,
      _array) {
      if ( _index == 2 ) {
        quiet =
          _value;
      }
      if ( _index == 3 ) {
        wallet_seed =
          _value;
      }
      if ( _index == 4 ) {
        target_network =
          _value;
      }
      if ( _index == 5 ) {
        api_key =
          _value;
      }
      if ( _index == 6 ) {
        target_address =
          _value;
      }
      if ( _index == 7 ) {
        display_unit =
          _value;
      }
      if ( _index == 8 ) {
        output_file =
          _value;
      }
      if ( _index == 9 ) {
        retries_max =
          _value;
      }
      if ( _index == 10 ) {
        call_timeout =
          _value;
      }
      if ( _value == "-h" ||
           _value == "--help" ) {
        _overrides_set();
        quiet =
          "n";
        _usage(
          0);
      }
  });
  if ( wallet_seed == "" &&
       target_address == "" ) {
    _msg =
      "You need to input either " +
      "a seed file path or a target " +
      "address."
    _msg_error(
      _msg,
      0);
    _overrides_set();
    _usage(
      1);
  }
}

async function
  _balance_get_cmdline(
    _app_opts) {
  let
    _balance;
  try {
    _balance =
      await _balance_get.apply(
        null,
        _app_opts);
    console.log(
      _balance.toString());
    // process.stdout.write(
    //   _balance.toString());
  }
  catch(
    _error) {
    _msg_error(
      _error,
      1);
    process.exit(
      1);
  }
}


if ( _cmdline_check(
       "balance-get") ||
     _cmdline_check(
       "gas-balance")) {
  _global_variables();
  _cmdline_parse();
  _config_show();
  app_opts = [
    wallet_seed,
    target_network,
    api_key,
    target_address,
    display_unit,
    output_file,
    retries_max
  ];
  _balance_get_cmdline(
    app_opts);
}

module.exports = {
  _balance_get:
    _balance_get
};
