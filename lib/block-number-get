async function
  _block_number_get(
    _target_network,
    _api_key_path,
    _output_file,
    _retries_max,
    _call_timeout) {
  let
    _block_number,
    _msg,
    _provider_get_opts,
    _retry,
    _request,
    _success,
    _time_over;
  if ( typeof(
         _retries_max) == 'undefined' ||
       _retries_max == "" ) {
    _retries_max =
      3;
  }
  else {
    _retries_max =
      Number(
        _retries_max);
  }
  if ( typeof(
         _call_timeout) == 'undefined' ||
       _call_timeout == "" ) {
    _call_timeout =
      100000;
  }
  _retry =
    0;
  _success =
    false;
  _provider_get_opts = [
    _target_network,
  ];
  if ( _output_file == undefined ) {
    _output_file =
      "";
  }
  if ( _api_key_path != "" ) {
    _api_key =
      _file_read(
        _api_key_path);
    _provider_get_opts.push(
      _api_key);
  }
  _provider_get_opts.push(
    _call_timeout);
  _provider =
    _provider_get.apply(
      null,
      _provider_get_opts);
  _msg_info_provider_generated(
    _provider);
  _msg =
    `Retrieving block number for ` +
    `network '${_target_network}'.`;
  _msg_info(
    _msg);
  while ( _success == false &&
          _retry < _retries_max ) {
    try {
      const
        _provider_get_block_number_cmd = [
          _provider
        ];
      // // TODO:
      // //   to ask why this doesnt work
      _block_number =
        await _run(
          "sync",
          _provider_get_block_number_cmd,
          "_provider_get_block_number",
          _call_timeout,
          "native",
	  "getBlockNumber");
      if ( _output_file != "" ) {
          _file_write(
            _output_file,
            _block_number.toString());
      }
      _success =
        true;
    } catch(
        _err) {
      _retry =
        _retry + 1;
      _msg =
        `Error retrieving block number `+
        `from network/rpc '${_target_network}', `
        `retrying (${_retry} of ${_retries_max})`;
      console.error(
        _err);
      _msg_error(
        _msg,
        0);
      await _sleep(
        3000);
    }
  }
  if ( _success == false &&
       _retry == _retries_max ) {
    _msg =
      "Error retrieving block number.";
    throw _msg;
  }
  return _block_number;
}

function
  _overrides_set() {
  if ( typeof(
         retries_max) == "undefined" ||
       retries_max == "" ) {
    retries_max =
      "1";
  }
  if ( typeof(
         call_timeout) == "undefined" ||
       call_timeout == "" ) {
    call_timeout =
      "30000";
  }
}

