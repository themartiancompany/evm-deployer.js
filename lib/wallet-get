const 
  { ethers } =
    require(
      "ethers");
_ethers = 
  ethers;
_hdnode_wallet =
  _ethers.HDNodeWallet

const
  _libcrash =
    require(
      "crash-js");
_cmdline_check =
  _libcrash._cmdline_check;
_msg_info = 
  _libcrash._msg_info;
_msg_info_obj = 
  _libcrash._msg_info_obj;
_msg_error = 
  _libcrash._msg_error;
_file_exists =
  _libcrash._file_exists;
_file_read =
  _libcrash._file_read;


function _global_variables() {
  app_name =
    "wallet-get";
}


function _wallet_exists(
  _path) {
  let
    _exists,
    _msg; 
  _exists =
    _file_exists(
      _path);
  if ( _exists == true ) {
    _msg =
      `Wallet '${_path}' already exists.`;
    _msg_error(
      _msg,
      "1");
  }
}

function
  _msg_error_seed_empty(
    _seed) {
  let
    _msg;
  _msg =
    `The seed '${_seed}' is empty.`;
  _msg_error(
    _msg,
    1)
}

function
  _msg_info_seed_loaded(
    _seed) {
  let
    _msg_obj,
    _phrase_show;
  if ( _seed_type == "file" ) {
    _msg_obj =
      "Seed file";
    _phrase_show =
      _seed;
  else if ( _seed_type == "string" ||
            _seed_type == "array" ) {
    _msg_obj =
      "Seed phrase";
    _phrase_show =
      "****";
  }
  _msg_info_obj(
    _msg_obj,
    _phrase_show);
}

function
  _seed_missing_error(
    _seed) {
  let
    _msg;
  _msg =
    `The seed '${_seed}' does not exist.`;
  _msg_error(
    _msg,
    1)
}

function
  _phrase_get(
    _seed) {
  let
    _seed_type,
    _seed_words;
  const
    _seed_type =
      typeof(
        _seed);
  if ( _seed_type == "undefined" ||
       _seed == "" ||
       _seed == [] ) {
    _seed_missing_error(
      _seed);
  }
  else {
    _seed_exists =
      _file_exists(
        _seed);
    if ( _seed_exists == false ) {
      if ( _seed_type == "string" ) {
        _seed_words =
          _seed.split(" ");
      else if ( _seed_type == "object" ) {
        _seed_words =
          _seed;
      }
      else {
        _msg =
          `Unknown seed type '${_seed_type}'.`;
        _msg_error(
          _msg,
          1);
      }
      const
        _seed_is_phrase =
          _seed_words.length == 12 ||
          _seed_words.length == 24;
      if ( _seed_type == "string" &&
           _seed_is_phrase ) {
        _seed_type =
          "string";
        _phrase =
          _seed;
      }
      else if ( _seed_type == "object" &&
                _seed_is_phrase ) {
        _seed_type =
          "array";
        _phrase =
          _seed.join(" ");
      }
      else {
        _msg =
          `Seed does not contain a valid phrase.`;
        _msg_error(
          _msg,
          1);
      }
    }
    else {
      _seed_type =
        "file";
      _phrase =
        _file_read(
          _seed); 
      _seed_words =
        _phrase.split(" ")
      _seed_is_phrase =
        _seed_words.length == 12 ||
        _seed_words.length == 24;
      if ( ! _seed_is_phrase ) {
        _msg =
          `The seed phrase is encrypted, ` +
	  `OpenPGP on Ethereum decryption not implemented.`;
        _msg_error(
          _msg,
          1)
      }
    }
  }
  _msg_info_seed_loaded(
    _seed,
    _seed_type);
  return _phrase;
}

function _wallet_get(
  _path,
  _password,
  _seed,
  _provider,
  _wallet) {
  let
    _password_show,
    _phrase,
    _phrase_show,
    _seed_exists,
    _seed_type;
  _password_show =
    "";
  if ( typeof(
         _password) == "undefined" ||
       _password != "" ) {
    _password_show="****" 
  }
  if ( ( typeof(
           _seed) == "undefined" ||
         _seed == "" ||
         _seed == [] ) &&
       ( typeof(
           _wallet) == "undefined" ||
         _wallet == "" ||
         _wallet == {} ) ) {
    _seed_missing_error(
      _seed);
  }
  _msg_info_obj(
    'Wallet path',
    _path);
  _msg_info_obj(
    'Wallet password',
    _password_show);
  _wallet_exists(
    _path);
  _phrase =
    _phrase_get(
      _seed);
  _wallet =
    _hdnode_wallet.fromPhrase(
      _phrase);
  _wallet.provider =
    _provider;
  _signer =
    _wallet.connect(
      _provider);
  return _signer;
}

if ( _cmdline_check(
       "wallet-get") ) {
  _global_variables();
}

module.exports = {
  _wallet_get:
    _wallet_get
};
