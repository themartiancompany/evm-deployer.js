/* global
     _parse_units */
const
  _parse_units =
    _ethers.parseUnits;
const
  _libcrash =
    require(
      "crash-js");
/* global
     _argv_get */
const
  _argv_get =
    _libcrash._argv_get;
/* global
     _basename */
const
  _basename =
    _libcrash._basename;
/* global
     _dirname */
const
  _dirname =
    _libcrash._dirname;
/* global
     _file_read */
const
  _file_read =
    _libcrash._file_read;
/* global
     _path_join */
const
  _path_join =
    _libcrash._path_join;
/* global
     _msg_info */
const
  _msg_info =
    _libcrash._msg_info;
