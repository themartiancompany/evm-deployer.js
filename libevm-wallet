async function
  _balance_update(
    _cache_dir,
    _wallet_name,
    _wallet_seed,
    _target_networks,
    _rpc,
    _api_key,
    _measure_unit,
    _retries_max,
    _balance_lifespan,
    _call_timeout) {
  let
    _balance,
    _balance_dir,
    _balance_file,
    _balance_file_modified,
    _balance_get_args,
    _life,
    _network;
  _balance =
    {};
  for ( _network of _target_networks ) {
    const
      _balance_dir =
        _path_join( [
          _cache_dir,
          _wallet_name,
          _network.toString() ]);
    const
      _balance_file =
        _path_join( [
          _balance_dir,
          "balance"]);
    const
      _balance_get_args = [
        _wallet_seed,
        _rpc[
          _network],
        _api_key,
        "",                  // Target address, using seed
        _measure_unit,
        _balance_file,
        _retries_max,
        _call_timeout
      ];
    if ( ! _file_exists(
             _balance_dir) ) {
      _mkdir(
        _balance_dir,
        { "recursive":
            true });
    }
    if ( ! _file_exists(
             _balance_file) ) {
      _balance[
        _network] =
        await _balance_get.apply(
          null,
          _balance_get_args);
    }
    else {
      const
        _balance_file_modified =
          _stat(
            _balance_file).mtimeMs;
      const
        _life =
          Date.now() -
          _balance_file_modified;
      if ( _balance_lifespan < _life ) {
        _balance[
          _network] =
          await _balance_get.apply(
            null,
            _balance_get_args);
      }
      else {
        _balance[
          _network] =
          _cat(
            _balance_file);
      }
    }
  }
  return _balance;
}

// will become async at some point
function
  _rpc_get(
    _target_networks) {
  let
    _evm_chains_info_args,
    _info_retrieve,
    _network,
    _network_type;
  const
    _rpc =
      {};
  for ( _network of _target_networks ) {
    _network_type =
      typeof(
        _network);
    if ( _network_type == "string" ) {
      if ( _network.startsWith(
             "https://") ) {
        _rpc[
          _network] =
          _network;
        _info_retrieve =
          "n";
      }
      else {
        _info_retrieve =
          "y";
      }
    }
    else if ( _network_type == "number" ) {
      _info_retrieve =
        "y";
    }
    else {
      _msg =
        `Unknown type '${_network_type}' ` +
        `for network variable.`;
      _msg_error(
        _msg,
        1);
    }
    if ( _info_retrieve == "y" ) {
      _evm_chains_info_args = [
        "get",            // command
        "id",             // input type 
        "rpc",            // output type
        "offline",        // retrieval method
        [ "node",         // db types
          "system" ],
        "kirsh",          // selection method
        "n",               // api key
        "n",              // all networks
        _network,
        []                // db paths
      ];
      _rpc[
        _network] =
        _evm_chains_info.apply(
          null,
          _evm_chains_info_args)[
            0];
    }
  }
  return _rpc;
}

async function
  _evm_wallet(
    _target_command,
    _wallet_name,
    _wallet_path,
    _wallet_password,
    _wallet_seed,
    _key_fingerprint,
    _config_dir,
    _cache_dir,
    _networks_all,
    _rpc_selection,
    _api_key,
    _retries_max,
    _tasks_parallel,
    _call_timeout,
    _measure_unit,
    _balance_lifespan,
    _currency_type,
    _currency_address,
    _output_type,
    _target_key,
    _target_value,
    _target_networks) {
  let
    _msg,
    _network,
    _target_network,
    _tx,
    _receipt;
  if ( typeof(
         _target_networks) == "undefined" ||
       _target_networks == [] ||
       _target_networks == "" ) {
    _target_networks =
      [];
  }
  if ( 0 < _target_networks.length ) {
    _target_network =
      _target_networks[
        0];
    if ( typeof(
           _target_network) == "object" ) {
      _target_networks =
        _target_network;
    }
  }
  else {
    _target_network =
      "";
  }
  if ( _target_networks.length == 1 ) {
    if ( typeof(
           _target_networks[0]) == "string" ) {
      if ( _target_networks[0].includes(",") ) {
        const
          _commas =
            _target_networks[0].split(",");
        if ( 2 < _commas.length ) {
          _target_networks =
            _commas;
        }
      }
    }
  }
  const
    _rpc =
      _rpc_get(
        _target_networks);
  _msg =
    `Using RPC address:`;
  _msg_info(
    _msg);
  if ( quiet == "n" ) {
    console.log(
      _rpc);
  }
  if ( _target_command == "gas" ) {
    const
      _price_gas_get_args = [
        _rpc[
          _target_network],
        _api_key,
        _measure_unit,
        "",            // seed
        "",            // target address
        "",            // output file
        _retries_max
      ];
    const
      _price_gas =
        await _price_gas_get.apply(
          null,
          _price_gas_get_args);
    return _price_gas;
  }
  else if ( _target_command == "get" ) {
    if ( _target_key == "balance" ) {
      const
        _balance_update_args = [
          _cache_dir,
          _wallet_name,
          _wallet_seed,
          _target_networks,
          _rpc,
          _api_key,
          _measure_unit,
          _retries_max,
          _balance_lifespan,
          _call_timeout
        ];
      const
        _balance =
          await _balance_update.apply(
            null,
            _balance_update_args);
      return _balance;
    }
    else if ( _target_key == "address" ) {
      const
        _address_get_args = [
          _wallet_seed,
          "",                 // Network
          "",                 // API Key
          "",                 // Chain ID
          "",                 // Chain name
          ""                  // Output file
        ];
      const
        _wallet_address =
          _address_get.apply(
            null,
            _address_get_args);
      return _wallet_address;
    }
    else {
      _msg =
        `Unknown key '${_target_key}'.`;
      _msg_info(
        _msg);
    }
  }
  else if ( _target_command == "send" ) {
    const
      _target_address =
        _target_key;
    const
      _target_amount =
        _target_value;
    if ( _currency_type == "gas" ) {
      const
        _balance_send_args = [
          _wallet_seed,
          _target_address,
          _target_amount,
          _rpc[
            _target_network],
          _api_key,
          _measure_unit
        ];
      [ _tx,
        _receipt ] =
        await _balance_send.apply(
          null,
          _balance_send_args);
      return [ _tx,
               _receipt ];
    }
    else if ( _currency_type == "erc20" ) {
      try {
        const
          _erc20_tools_module =
            require(
              "erc20-tools");
        const
          _token_send =
            _erc20_tools_module._token_send;
        const
          _token_send_args = [
            _retries_max,
            _call_timeout,
            _wallet_seed,
            _api_key,
            _rpc,                          // NOTE: data filled-in
            _currency_address,             // by 'token-send':
            "",                            //   erc20 abi
            "",                            //   erc20 bytecode
            "",                            //   erc20 hardhat artifact
            _measure_unit,
            "",                            // output path
            _target_address,
            _target_amount
          ];
        _msg =
          `Running '_token_send' with ` +
          `arguments '${_token_send_args}'.`;
        _msg_info(
          _msg);
        const
          _token_sent =
            await _token_send.apply(
              null,
              _token_send_args);
        return _token_sent;
      }
      catch(
        _error) {
        _msg =
          "Install ERC-20 Tools ('ur erc20-tools')";
        _msg_error(
          _msg,
          1);
      }
    }
    else {
      _msg =
        `Unknown currency type '${_currency_type}'.`;
      _msg_error(
        _msg,
        1);
    }
  }
  else if ( _target_command == "run" ) {
    true;
  }
  else {
    _msg =
      `Unknown command '${_target_command}'.`;
    _msg_error(
      _msg,
      1);
  }
}

