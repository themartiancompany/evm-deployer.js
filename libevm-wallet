async function
  _evm_wallet(
    _target_command,
    _wallet_name,
    _wallet_path,
    _wallet_password,
    _wallet_seed,
    _key_fingerprint,
    _config_dir,
    _cache_dir,
    _networks_all,
    _rpc_selection,
    _api_key,
    _retries_max,
    _tasks_parallel,
    _call_timeout,
    _measure_unit,
    _balance_lifespan,
    _currency_type,
    _currency_address,
    _output_type,
    _target_key,
    _target_value,
    _target_networks) {
  let
    _args,
    _msg;
  const
    _cmd =
      "";
  const
    _target_network =
      _target_networks[
        0];
  const
    _evm_chains_info_args = [
      "get",            // command
      "id",             // input type 
      "rpc",            // output type
      "offline",        // retrieval method
      [ "node",         // db types
        "system" ],
      "kirsh",          // selection method
      "",               // api key
      "n",              // all networks
      _target_network,
      []                // db paths
    ];
  const
    _rpc =
      _evm_chains_info.apply(
        null,
        _evm_chains_info_args)[
        0];
  _msg =
    `Got rpc '${_rpc}'.`;
  _msg_info(
    _msg);
  if ( _target_command == "get" ) {
    if ( _target_key == "balance" ) {
      const
        _balance_dir =
          _path_join( [
            _cache_dir,
            _wallet_name,
            _target_network.toString() ]);
      const
        _balance_file =
          _path_join( [
            _balance_dir,
            "balance"]);
      if ( ! _file_exists(
               _balance_dir) ) {
        _mkdir(
	  _balance_dir,
          { "recursive":
              true });
      }
      const
        _balance_get_args = [
          _wallet_seed,
          _rpc,
          _api_key,
          "",                  // Target address, using seed
          _measure_unit,
          _balance_file,
          _retries_max
        ];
      const
        _balance =
          await _balance_get.apply(
            null,
            _balance_get_args);
      return _balance;
    }
    else if ( _target_key == "address" ) {
      const
        _address_get_args = [
          _wallet_seed,
          "",                 // Network
          "",                 // API Key
          "",                 // Chain ID
          "",                 // Chain name
          ""                  // Output file
        ];
      const
        _wallet_address =
          _address_get.apply(
            null,
            _address_get_args);
      return _wallet_address;
    }
    else {
      _msg =
        `Unknown key '${_target_key}'.`;
      _msg_info(
        _msg);
    }
  }
  else if ( _target_command == "send" ) {
    if ( _currency_type == "gas" ) {
      const
        _balance_send_args = [
          _wallet_seed,
          _target_address,
          _target_amount,
          _rpc,
          _api_key,
          _measure_unit
	];
      true;
      _balance_send();
    }
    else if ( _currency_type == "gas" ) {
      const
        _erc20_tools_module =
          require(
            "erc20-tools");
      const
        _token_send =
          _erc20_tools_module._token_send;
    true;
    }
    else {
      _msg =
        `Unknown currency type '${_currency_type}'.`;
    }
  }
  else if ( _target_command == "run" ) {
    true;
  }
  else {
    _msg =
      `Unknown command '${_target_command}'.`;
    _msg_error(
      _msg,
      1);
  }
}

