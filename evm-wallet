function
  _tasks_parallel_auto_detect() {
  if ( networks_all == "y" ) {
    tasks_parallel =
      10;
  }
  else if ( networks_all == "n" ) {
    tasks_parallel =
      1;
  }
  else {
    _msg =
      `Invalid value '${tasks_parallel}' ` +
      `for variable '${tasks_parallel}'`;
  }
}

function
  _call_timeout_auto_detect() {
  if ( target_command == "get" ) {
    call_timeout =
      "30";
  }
  else {
    call_timeout =
      "300";
  }
}

function
  _target_key_auto_detect() {
  if ( target_command == "get" ) {
    target_key =
