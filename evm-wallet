  let
    _flag,
    _output_types,
    _type;
  _flag =
    "false";
  _output_types = [
    "",
    "name",
    "address",
    "fingerprint"
  ];
  for ( _type of _output_types ) {
    if ( output_type == _type ) {
      _flag =
        "true";
      break
    }
  }
  if ( flag == "false" ) {
    _msg =
      `Invalid output type '${output_type}'.`;
  }
}

function 
  _overrides_set() {
  if ( call_date == "" ) {
    call_date =
      _get_date_human();
  }
  if ( target_command == "" ) {
    target_command =
      "get";
  }
  if ( networks_all == "" ) {
    networks_all =
      "n";
  }
  _tasks_parallel_auto_detect();
  _call_timeout_auto_detect();
  if ( config_dir == "" ) {
    config_dir =
      `${_homedir_get()}/.config/evm-wallet`;
  }
  if ( target_networks.length < 1 &&
       networks_all == "n" ) {
    target_networks.push(
      100);
  }
  _target_key_auto_detect();
  if ( balance_lifespan == "" ) {
    balance_lifespan =
      "3600";
  }
  if ( retries_max == "" ) {
    retries_max =
      "2";
  }
  if ( measure_unit == "" ) {
    measure_unit =
      "ether";
  }
  if ( currency_type == "" ) {
    if ( currency_address == "" ) {
      currency_type =
        "gas";
    }
    else if ( currency_address != "" ) {
      currency_type =
        "erc20";
    }
  }
  if ( rpc_selection == "" ) {
    // TODO:
    //   remove all references to that
    //   monster
    rpc_selection =
      "kirsh";
  }
  if ( explorer_selection == "" ) {
    // TODO:
    //   remove all references to that
    //   humunculus
    explorer_selection =
      "kirsh";
  }
  // TODO:
  //   explorers api keys, optional frankly
  //   since theres the evm-contracts-source-index
  _wallet_overrides_set( 
    "evm-wallet",
    wallet_name,
    "y",
    "n");
  _key_fingerprint_auto_detect();
  _output_type_check();
  // See https://github.com/openpgpjs/openpgpjs/issues/2004
  if ( qr_support == "" ) {
    qr_support =
      "n";
  }
}

