    `       Chunks amount only:   ${amount_only}`,
    `                  In file:   ${in_file}`,
    `          Out text prefix:   ${out_txt_prefix}`,
  ];
  for ( _line of _text ) {
    _msg_info(
      _line);
  }
}

function
  _usage(
    _exit_code) {
  let
    _line,
    _text;
  _text = [
    "Converts binary to ascii text.",
    "",
    "Usage:",
    "",
    "  bin2txt",
    "    <in-file>",
    "    <out-txt-prefix>",
    "",
    "  arguments:",
    "    <in-file>                        An input file.",
    "    <out-file-prefix>                Prefix for the output file(s).",
    "",
    "  options:",
    "",
    "     -f --encoding-format            Encoding format ('base64').",
    `       <encoding-format>             Default: '${encoding_format}`,
    "",
    "     -B --buffer-size                Size in bytes the input file will",
    "       <buffer-size>                 be split before being read",
    "                                     in memory and passed to",
    "                                     the encoder.",
    `                                     Default: '${buffer_size}'`,
    "",
    "     -L --string-length              String chunk length.",
    `       <string-length>               Default: '${string_length}'`,
    "",
    "     -s --amount-only                Only print chunks amount.",
    `                                     Default: '${amount_only}'`,
    "",
    "     -h --help                       This message.",
    "     -v --verbose                    Enable verbose output."
  ];
  for ( _line of _text ) {
    console.log(
      _line);
  }
  process.exit(
    _exit_code);
}

function 
  _cmdline_parse() {
  let
    _argv,
    _help_display,
    _msg;
  _argv =
    _argv_get();
  _options =
    _argv[
      "_"];
  quiet = 
    "y";
  runtime_environment =
    "node";
  if ( _options.indexOf(
         "--help") > -1 ||
       _options.indexOf(
         "-h") > -1) {
    _help_display =
      true;
  }
  if ( _help_display ) {
    quiet =
      "n";
    _usage(
      0);
  }
  if ( typeof(
         _argv) == "undefined" ||
       _argv[
         "_"].length < 1 ) {
    _msg =
      "Input file argument required.";
    _msg_error(
      _msg,
      0);
    _usage(
      1);
  }
  in_file =
    _argv[
      "_"][
        0];
  if ( _argv[
         "_"].length < 2 ) {
    out_txt_prefix =
      in_file +
      ".base64";
  }
  if ( "L" in _argv ) {
    string_length =
      _argv[
        "L"];
  }
  if ( "string-length" in _argv ) {
    string_length =
      _argv[
        "string-length"];
  }
  if ( "s" in _argv ) {
    amount_only =
      _argv[
        "s"];
  }
  if ( "amount-only" in _argv ) {
    amount_only =
      _argv[
        "amount-only"];
  }
  if ( "v" in _argv ) {
    verbose =
      _argv[
        "v"];
  }
  if ( "verbose" in _argv ) {
    verbose =
      _argv[
        "verbose"];
  }
  if ( verbose ) {
    quiet =
      "n";
  }
}

function
  _url_parse() {
